{
  "items": [
    {
      "name": "Button Handler [BETA]",
      "priority": -1,
      "items": [
        {
          "name": "Start",
          "if": "\"/tmp/kbh.pid\" -f!",
          "action": "./button_handler_main.sh",
          "params": "start",
          "exitmenu": false,
          "refresh": true,
          "status": false,
          "internal": "status Start the gesture engine daemon"
        },
        {
          "name": "Stop",
          "if": "\"/tmp/kbh.pid\" -f",
          "action": "./button_handler_main.sh",
          "params": "stop",
          "exitmenu": false,
          "refresh": true,
          "status": false,
          "internal": "status Stop the gesture engine daemon"
        },
        {
          "name": "Restart",
          "action": "./button_handler_main.sh",
          "params": "restart",
          "exitmenu": false,
          "refresh": true,
          "status": false,
          "internal": "status Restart the gesture engine daemon"
        },
        {
          "name": "Capture: POWER button  (press w/in 12s)",
          "action": "./button_handler_main.sh",
          "params": "cap_power",
          "exitmenu": false,
          "refresh": false,
          "status": false,
          "internal": "status Tap then press the physical power button"
        },
        {
          "name": "Capture: NEXT PAGE button  (press w/in 12s)",
          "action": "./button_handler_main.sh",
          "params": "cap_next",
          "exitmenu": false,
          "refresh": false,
          "status": false,
          "internal": "status Tap then press the physical next-page button"
        },
        {
          "name": "Capture: PREV PAGE button  (press w/in 12s)",
          "action": "./button_handler_main.sh",
          "params": "cap_back",
          "exitmenu": false,
          "refresh": false,
          "status": false,
          "internal": "status Tap then press the physical prev-page button"
        },
        {
          "name": "Recognized Buttons",
          "if": "\"/mnt/us/extensions/button_handler/config\" -f",
          "items": [
            {
              "name": "Power button",
              "action": "./button_handler_main.sh",
              "params": "btn_power",
              "exitmenu": false,
              "refresh": false,
              "status": false,
              "internal": "status Device, code, gestures for power button"
            },
            {
              "name": "Next-page button",
              "action": "./button_handler_main.sh",
              "params": "btn_next",
              "exitmenu": false,
              "refresh": false,
              "status": false,
              "internal": "status Device, code, gestures for next-page button"
            },
            {
              "name": "Prev-page button",
              "action": "./button_handler_main.sh",
              "params": "btn_back",
              "exitmenu": false,
              "refresh": false,
              "status": false,
              "internal": "status Device, code, gestures for prev-page button"
            }
          ]
        },
        {
          "name": "--- Daemon: RUNNING ---",
          "if": "\"/tmp/kbh.pid\" -f",
          "action": "./button_handler_main.sh",
          "params": "menu",
          "exitmenu": false,
          "refresh": false,
          "status": false,
          "internal": "status Daemon is active"
        },
        {
          "name": "--- Daemon: STOPPED ---",
          "if": "\"/tmp/kbh.pid\" -f!",
          "action": "./button_handler_main.sh",
          "params": "menu",
          "exitmenu": false,
          "refresh": false,
          "status": false,
          "internal": "status Daemon is not running"
        },
        {
          "name": "--- Config: NOT SET  (run Capture first) ---",
          "if": "\"/mnt/us/extensions/button_handler/config\" -f!",
          "action": "./button_handler_main.sh",
          "params": "menu",
          "exitmenu": false,
          "refresh": false,
          "status": false,
          "internal": "status No button config found"
        },
        {
          "name": "--- Power button: SET ---",
          "if": "\"/mnt/us/extensions/button_handler/config\" -f \"/mnt/us/extensions/button_handler/config\" \"^BTN_POWER_CODE=\" -g &&",
          "action": "./button_handler_main.sh",
          "params": "menu",
          "exitmenu": false,
          "refresh": false,
          "status": false,
          "internal": "status Power button code is captured"
        },
        {
          "name": "--- Next-page button: SET ---",
          "if": "\"/mnt/us/extensions/button_handler/config\" -f \"/mnt/us/extensions/button_handler/config\" \"^BTN_NEXT_CODE=\" -g &&",
          "action": "./button_handler_main.sh",
          "params": "menu",
          "exitmenu": false,
          "refresh": false,
          "status": false,
          "internal": "status Next-page button code is captured"
        },
        {
          "name": "--- Prev-page button: SET ---",
          "if": "\"/mnt/us/extensions/button_handler/config\" -f \"/mnt/us/extensions/button_handler/config\" \"^BTN_BACK_CODE=\" -g &&",
          "action": "./button_handler_main.sh",
          "params": "menu",
          "exitmenu": false,
          "refresh": false,
          "status": false,
          "internal": "status Prev-page button code is captured"
        }
      ]
    }
  ]
}
