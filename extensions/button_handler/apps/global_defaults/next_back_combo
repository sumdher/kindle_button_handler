#!/bin/sh
# next_back_combo — hold next-page, tap prev-page (global_defaults profile)
# Action: toggle night mode (display inversion Y8 ↔ Y8INV)

cur=$(lipc-get-prop com.lab126.winmgr epdcMode 2>/dev/null)
if [ "$cur" = "Y8INV" ]; then
    lipc-set-prop com.lab126.winmgr epdcMode Y8
else
    lipc-set-prop com.lab126.winmgr epdcMode Y8INV
fi
