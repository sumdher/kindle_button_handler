#!/bin/sh
# back_next_combo2 — hold prev-page, tap next-page TWICE (global_defaults profile)
# Action: toggle warm light (amber) on/off

cur=$(lipc-get-prop -i com.lab126.powerd currentAmberLevel 2>/dev/null)
if [ "$cur" -gt 0 ]; then
    lipc-set-prop com.lab126.powerd currentAmberLevel 0
else
    lipc-set-prop com.lab126.powerd currentAmberLevel 24
fi
