#!/bin/sh
# next_back_combo3 — hold next-page, tap prev-page THREE times (global_defaults profile)
# Action: decrease warm light (amber) level by 4 (min 0)

cur=$(lipc-get-prop -i com.lab126.powerd currentAmberLevel 2>/dev/null)
cur=${cur:-0}
next=$((cur - 4))
[ "$next" -lt 0 ] && next=0
lipc-set-prop com.lab126.powerd currentAmberLevel "$next"
