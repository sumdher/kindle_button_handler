#!/bin/sh
# Kindle Button Handler [BETA] — Gesture Engine
# Runs as background daemon. Dispatches gestures to user action scripts.
#
# Gestures:
#   back_short / back_long
#   next_short / next_long
#   power_long / power_long_tap1..N
#   back_next_combo / next_back_combo
#
# Action scripts live at:
#   /mnt/us/documents/button_handler/apps/<process_name>/<gesture>
#   /mnt/us/documents/button_handler/apps/default/<gesture>
#
# The engine searches for a running process matching the app dir name.
# Falls back to "default" if none match.
#
# BETA: next and back must share the same event device.

DATA="/mnt/us/documents/button_handler"
TMP="/tmp/kbh"

[ -f "$DATA/config" ] || { echo "handler: missing $DATA/config — run wizard first" >&2; exit 1; }
. "$DATA/config"

LONG_PRESS_MS="${LONG_PRESS_MS:-800}"
PWR_LONG_MS="${PWR_LONG_MS:-1000}"
TAP_WINDOW_MS="${TAP_WINDOW_MS:-400}"
MAX_TAPS="${MAX_TAPS:-3}"

DEV_PWR="/dev/input/${BTN_POWER_EVENT:-event1}"
DEV_PAGE="/dev/input/${BTN_NEXT_EVENT:-event3}"
NEXT_CODE="${BTN_NEXT_CODE:-6800}"
BACK_CODE="${BTN_BACK_CODE:-6D00}"
PWR_CODE="${BTN_POWER_CODE:-7400}"

ms() { awk '{printf "%d\n", $1*1000}' /proc/uptime; }

# Find and run the action script for a gesture.
# Checks named app dirs (dirname = pgrep pattern), falls back to default.
fire() {
    local gesture="$1"
    local script=""
    local app

    for app in "$DATA/apps"/*/; do
        local name="${app%/}"
        name="${name##*/}"
        [ "$name" = "default" ] && continue
        pgrep -f "$name" >/dev/null 2>&1 || continue
        [ -x "${app}${gesture}" ] || continue
        script="${app}${gesture}"
        break
    done

    [ -z "$script" ] && [ -x "$DATA/apps/default/$gesture" ] && \
        script="$DATA/apps/default/$gesture"

    [ -n "$script" ] && "$script" &
}

# --- Power button background reader ---
# Writes press/release timestamps to temp files.
# Main loop polls these — no FIFO needed, proven on busybox ash.
pwr_reader() {
    while true; do
        ev=$(dd if="$DEV_PWR" bs=16 count=1 2>/dev/null | hexdump -v -e '16/1 "%02X"')
        t="${ev:16:4}"; c="${ev:20:4}"; v="${ev:24:8}"
        [ "$t" = "0100" ] && [ "$c" = "$PWR_CODE" ] || continue
        [ "$v" = "01000000" ] && ms > "${TMP}_pp"
        [ "$v" = "00000000" ] && ms > "${TMP}_pr"
    done
}

# --- Power gesture state ---
pwr_last=0
pwr_long=0
pwr_taps=0
pwr_win=0

check_power() {
    local pp pr now hold age
    pp=$(cat "${TMP}_pp" 2>/dev/null)
    pr=$(cat "${TMP}_pr" 2>/dev/null)
    [ -z "$pp" ] || [ -z "$pr" ] && return

    now=$(ms)

    if [ "$pr" = "$pwr_last" ]; then
        # No new release — check if tap window expired
        if [ "$pwr_long" = "1" ] && [ "$pwr_win" -gt 0 ]; then
            age=$((now - pwr_win))
            if [ "$age" -ge "$TAP_WINDOW_MS" ]; then
                [ "$pwr_taps" -ge 1 ] && fire "power_long_tap${pwr_taps}"
                pwr_taps=0
                pwr_win=0
                pwr_long=0
            fi
        fi
        return
    fi

    hold=$((pr - pp))

    if [ "$hold" -ge "$PWR_LONG_MS" ]; then
        fire "power_long"
        pwr_long=1
        pwr_taps=0
        pwr_win=0
    elif [ "$pwr_long" = "1" ]; then
        pwr_taps=$((pwr_taps + 1))
        if [ "$pwr_taps" -ge "$MAX_TAPS" ]; then
            fire "power_long_tap${pwr_taps}"
            pwr_taps=0
            pwr_win=0
            pwr_long=0
        else
            pwr_win=$(ms)
        fi
    fi

    pwr_last="$pr"
}

# --- Page button state ---
bh=0; bt=0
nh=0; nt=0
cf=0

trap 'kill $(jobs -p) 2>/dev/null; rm -f ${TMP}_pp ${TMP}_pr' EXIT

pwr_reader &

# --- Main loop ---
# Blocks on page button device. Checks power state at top of each iteration.
# NOTE (beta): power tap-window expiry fires on the next page-button event.
while true; do
    [ -f "/tmp/kbh_paused" ] && { sleep 1; continue; }

    check_power

    ev=$(dd if="$DEV_PAGE" bs=16 count=1 2>/dev/null | hexdump -v -e '16/1 "%02X"')
    [ "${#ev}" -lt 28 ] && continue
    t="${ev:16:4}"; c="${ev:20:4}"; v="${ev:24:8}"
    [ "$t" = "0100" ] || continue

    if [ "$c" = "$BACK_CODE" ]; then
        if [ "$v" = "01000000" ]; then
            bh=1; bt=$(ms)
            [ "$nh" = "0" ] && cf=0
        else
            bh=0
            if [ "$cf" = "1" ]; then
                [ "$nh" = "0" ] && cf=0
            elif [ "$nh" = "1" ]; then
                fire "next_back_combo"; cf=1; bt=0
            elif [ "$bt" -gt 0 ]; then
                e=$(($(ms) - bt))
                [ "$e" -ge "$LONG_PRESS_MS" ] && fire "back_long" || fire "back_short"
            fi
            bt=0
        fi

    elif [ "$c" = "$NEXT_CODE" ]; then
        if [ "$v" = "01000000" ]; then
            nh=1; nt=$(ms)
            [ "$bh" = "0" ] && cf=0
        else
            nh=0
            if [ "$cf" = "1" ]; then
                [ "$bh" = "0" ] && cf=0
            elif [ "$bh" = "1" ]; then
                fire "back_next_combo"; cf=1; nt=0
            elif [ "$nt" -gt 0 ]; then
                e=$(($(ms) - nt))
                [ "$e" -ge "$LONG_PRESS_MS" ] && fire "next_long" || fire "next_short"
            fi
            nt=0
        fi
    fi
done
